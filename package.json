{
  "name": "@quiquemz/fhir-ui",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "node --max_old_space_size=8192 node_modules/nx/bin/nx.js run-many --target=test --all --output-style=compact",
    "test:ci": "node --max_old_space_size=8192 node_modules/nx/bin/nx.js run-many --runInBand --target=test --reporters='jest-junit,jest-sonar' --uniqueOutputName=true --all",
    "test:coverage": "npm run test -- --ci --coverage --reporters='default' --reporters='jest-junit' --coverageReporters=html --coverageReporters=cobertura",
    "test:coverage:ci": "npm run test:ci -- --ci --coverage --coverageReporters=lcov"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "21.2.1",
    "@angular/cdk": "21.2.1",
    "@angular/common": "21.2.1",
    "@angular/compiler": "21.2.1",
    "@angular/core": "21.2.1",
    "@angular/forms": "21.2.1",
    "@angular/material": "21.2.1",
    "@angular/platform-browser": "21.2.1",
    "@angular/platform-browser-dynamic": "21.2.1",
    "@angular/router": "21.2.1",
    "@azure/msal-angular": "^3.0.23",
    "@azure/msal-browser": "^3.20.0",
    "@fontsource/inter": "^5.2.8",
    "@ngrx/component-store": "^21.0.1",
    "@ngrx/effects": "^21.0.1",
    "@ngrx/entity": "^21.0.1",
    "@ngrx/store": "^21.0.1",
    "@ngrx/store-devtools": "^21.0.1",
    "@types/fhir": "^0.0.41",
    "js-yaml": "4.1.0",
    "material-design-icons-iconfont": "^6.7.0",
    "material-icons": "^1.13.12",
    "rxjs": "~7.8.0",
    "storybook": "^10.1.0",
    "swagger-ui-dist": "^5.17.14",
    "tslib": "^2.3.0",
    "vis-network": "^9.1.9",
    "zone.js": "0.16.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "21.2.1",
    "@angular/cli": "21.2.1",
    "@angular/compiler-cli": "21.2.1",
    "@faker-js/faker": "^8.2.0",
    "@nx/angular": "22.5.4",
    "@nx/cypress": "22.5.4",
    "@nx/eslint": "22.5.4",
    "@nx/eslint-plugin": "22.5.4",
    "@nx/jest": "22.5.4",
    "@nx/js": "22.5.4",
    "@nx/storybook": "22.5.4",
    "@nx/web": "22.5.4",
    "@nx/workspace": "22.5.4",
    "@types/d3": "^7.4.3",
    "@types/jasmine": "~5.1.0",
    "esbuild": "^0.19.2",
    "jasmine-core": "~5.1.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "nx": "22.5.4",
    "prettier": "3.3.3",
    "typescript": "^5.9.3"
  },
  "nx": {
    "includedScripts": [],
    "projectType": "application",
    "generators": {
      "@schematics/angular:component": {
        "style": "scss"
      }
    },
    "sourceRoot": "src",
    "prefix": "app",
    "targets": {
      "build": {
        "executor": "@angular-devkit/build-angular:application",
        "options": {
          "outputPath": "dist/fhir-ui",
          "index": "src/index.html",
          "browser": "src/main.ts",
          "polyfills": [
            "zone.js"
          ],
          "tsConfig": "tsconfig.app.json",
          "inlineStyleLanguage": "scss",
          "assets": [
            "src/favicon.svg",
            "src/assets",
            {
              "glob": "**/*",
              "input": "config",
              "output": "/config/"
            }
          ],
          "styles": [
            "node_modules/@angular/cdk/overlay-prebuilt.css",
            "node_modules/swagger-ui-dist/swagger-ui.css",
            "node_modules/@fontsource/inter/400.css",
            "node_modules/@fontsource/inter/500.css",
            "node_modules/@fontsource/inter/600.css",
            "node_modules/@fontsource/inter/700.css",
            "node_modules/material-icons/iconfont/material-icons.css",
            "src/styles.scss"
          ],
          "scripts": [
            "node_modules/swagger-ui-dist/swagger-ui-bundle.js",
            "node_modules/swagger-ui-dist/swagger-ui-standalone-preset.js"
          ]
        },
        "configurations": {
          "production": {
            "budgets": [
              {
                "type": "initial",
                "maximumWarning": "500kb",
                "maximumError": "10mb"
              },
              {
                "type": "anyComponentStyle",
                "maximumWarning": "4kb",
                "maximumError": "8kb"
              }
            ],
            "outputHashing": "all"
          },
          "development": {
            "optimization": false,
            "extractLicenses": false,
            "sourceMap": true
          }
        },
        "defaultConfiguration": "production"
      },
      "serve": {
        "executor": "@angular-devkit/build-angular:dev-server",
        "configurations": {
          "fhir": {
            "buildTarget": "fhir-ui:build:development",
            "proxyConfig": "src/proxy/proxy.conf.fhir.json"
          }
        },
        "defaultConfiguration": "fhir",
        "continuous": true
      },
      "extract-i18n": {
        "executor": "@angular-devkit/build-angular:extract-i18n",
        "options": {
          "buildTarget": "fhir-ui:build"
        }
      },
      "test": {
        "executor": "@angular-devkit/build-angular:karma",
        "options": {
          "polyfills": [
            "zone.js",
            "zone.js/testing"
          ],
          "tsConfig": "tsconfig.spec.json",
          "inlineStyleLanguage": "scss",
          "assets": [
            "src/favicon.svg",
            "src/assets"
          ],
          "styles": [
            "src/styles.scss",
            "node_modules/material-icons/iconfont/material-icons.css"
          ],
          "scripts": []
        }
      }
    },
    "name": "fhir-ui"
  }
}
